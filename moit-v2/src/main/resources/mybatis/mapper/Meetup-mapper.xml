<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moit.meetup.dao.MeetupMapper">
	<select id="findById" resultType="com.moit.meetup.dto.MeetupDto">
	    SELECT
	        meetup_id,
	        member_id
	    FROM meetups
	    WHERE meetup_id = #{meetupId}
	</select>
</mapper>

